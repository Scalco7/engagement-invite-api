{
  "openapi": "3.0.0",
  "info": {
    "title": "Engagement Invite API",
    "version": "1.0.0",
    "description": "API em Express com TypeScript configurada para rodar no Vercel"
  },
  "servers": [
    {
      "url": "/",
      "description": "Servidor Dinâmico (detecta automaticamente o host local ou do Vercel)"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Rota de boas-vindas da API",
        "responses": {
          "200": {
            "description": "API online",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "status": { "type": "string" },
                    "version": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api": {
      "get": {
        "summary": "Status do roteador da API",
        "responses": {
          "200": {
            "description": "Resposta do roteador principal",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "summary": "Health check do servidor",
        "responses": {
          "200": {
            "description": "API saudável",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" },
                    "uptime": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/db-test": {
      "get": {
        "summary": "Testa a conexão com o banco de dados Postgres via Neon",
        "responses": {
          "200": {
            "description": "Conectado ao banco de dados com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "result": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "db_time": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro de conexão com o banco",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/rsvp": {
      "get": {
        "summary": "Lista todas as confirmações de convite enviadas",
        "responses": {
          "200": {
            "description": "Lista de RSVPs obtida com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "count": { "type": "integer" },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string", "format": "uuid" },
                          "name": { "type": "string" },
                          "phone_number": { "type": "string" },
                          "will_go": { "type": "boolean" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Salva uma confirmação ou rejeição de convite (RSVP)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "phone_number", "will_go"],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 100,
                    "description": "Nome do convidado (mínimo 2, máximo 100 caracteres)"
                  },
                  "phone_number": {
                    "type": "string",
                    "description": "Número de telefone. Será higienizado e prefixado com +55 se necessário (mínimo 8, máximo 15 dígitos numéricos)"
                  },
                  "will_go": {
                    "type": "boolean",
                    "description": "Informa se o convidado aceita (true) ou rejeita (false) o convite"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Confirmação salva com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid" },
                        "name": { "type": "string" },
                        "phone_number": { "type": "string" },
                        "will_go": { "type": "boolean" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erro de validação nos dados enviados",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor ao salvar no banco",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
