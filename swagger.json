{
  "openapi": "3.0.0",
  "info": {
    "title": "Engagement Invite API",
    "version": "1.0.0",
    "description": "API em Express com TypeScript configurada especificamente para rodar no Vercel de forma serverless, conectada ao Neon Postgres."
  },
  "servers": [
    {
      "url": "/",
      "description": "Servidor Dinâmico (detecta automaticamente o host local ou do Vercel)"
    }
  ],
  "tags": [
    {
      "name": "RSVP",
      "description": "Gerenciamento de presença dos convidados para a festa de noivado"
    },
    {
      "name": "Bolão",
      "description": "Gerenciamento de palpites (bets) e cálculo dinâmico de odds para a festa de noivado"
    },
    {
      "name": "System Status",
      "description": "Endpoints de integridade, saúde e verificação técnica da infraestrutura"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["System Status"],
        "summary": "Rota de boas-vindas da API",
        "description": "Verifica se o servidor Express está ativo e responde adequadamente na porta correspondente, fornecendo links da documentação.",
        "responses": {
          "200": {
            "description": "API online e respondendo",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Welcome to the Engagement Invite API"
                    },
                    "status": {
                      "type": "string",
                      "example": "online"
                    },
                    "version": {
                      "type": "string",
                      "example": "1.0.0"
                    },
                    "documentation": {
                      "type": "string",
                      "example": "/api-docs"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api": {
      "get": {
        "tags": ["System Status"],
        "summary": "Status do roteador da API",
        "description": "Informa se o roteador central Express montado no prefixo `/api` está ativo.",
        "responses": {
          "200": {
            "description": "Roteador active",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Hello from the Engagement Invite API Router!"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "tags": ["System Status"],
        "summary": "Health check do servidor",
        "description": "Retorna o status geral da API Express, incluindo um timestamp e o tempo de atividade acumulado (uptime) do servidor.",
        "responses": {
          "200": {
            "description": "API saudável",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2026-06-17T23:37:00.000Z"
                    },
                    "uptime": {
                      "type": "number",
                      "example": 124.52
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/db-test": {
      "get": {
        "tags": ["System Status"],
        "summary": "Testa a conexão com o banco de dados (Neon)",
        "description": "Executa uma query nativa rápida (`SELECT NOW()`) utilizando o driver de WebSocket da Neon para confirmar a saúde da conexão ativa com o Postgres.",
        "responses": {
          "200": {
            "description": "Conectado ao banco de dados com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "connected"
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "db_time": {
                            "type": "string",
                            "format": "date-time",
                            "example": "2026-06-17T23:08:21.000Z"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro de conexão ou comunicação com o Postgres",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/rsvp": {
      "get": {
        "tags": ["RSVP"],
        "summary": "Lista todas as confirmações de convite enviadas",
        "description": "Retorna o histórico completo com todas as confirmações de presença registradas pelos noivos no banco Postgres.",
        "responses": {
          "200": {
            "description": "Lista de RSVPs obtida com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "count": {
                      "type": "integer",
                      "example": 12
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Rsvp"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor ao ler do banco",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["RSVP"],
        "summary": "Salva uma confirmação ou rejeição de convite (RSVP)",
        "description": "Recebe o formulário de resposta do convidado, higieniza o telefone aplicando a regra do prefixo nacional brasileiro `+55` e salva no banco de dados. Valida se os campos seguem regras estritas de segurança.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RsvpInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Confirmação salva com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "Confirmação de convite salva com sucesso!"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Rsvp"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Falha de validação de dados (parâmetros ausentes, incorretos ou fora dos limites)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor ao salvar no banco",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/rsvp/lookup": {
      "post": {
        "tags": ["RSVP"],
        "summary": "Recupera o RSVP de um convidado por e-mail e telefone",
        "description": "Busca os dados de confirmação de convite do convidado associado ao e-mail e telefone informados. O telefone é sanitizado e formatado com DDI +55 antes da busca.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "phone_number"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "E-mail do convidado.",
                    "example": "maria.silva@example.com"
                  },
                  "phone_number": {
                    "type": "string",
                    "description": "Telefone do convidado.",
                    "example": "(11) 99999-9999"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dados do RSVP retornados com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Rsvp"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Falha na validação dos campos de busca",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Nenhum RSVP correspondente encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/bets/questions": {
      "get": {
        "tags": ["Bolão"],
        "summary": "Lista todas as perguntas do bolão com as odds calculadas",
        "description": "Recupera todas as perguntas cadastradas para o bolão e calcula em tempo real as odds de cada opção com base nos palpites atuais dos convidados (modelo de mercado totalizador).",
        "responses": {
          "200": {
            "description": "Lista de perguntas com cotações obtida com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "count": {
                      "type": "integer",
                      "example": 5
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/QuestionWithOdds"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor ao consultar o banco",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Bolão"],
        "summary": "Cadastra uma nova pergunta no bolão",
        "description": "Cria uma nova pergunta para o bolão de palpites. Suporta perguntas de digitação livre (TEXT), numérica (NUMBER) ou seleção dinâmica de convidados confirmados (GUEST_SELECT).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BetQuestionInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pergunta criada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "Pergunta do bolão criada com sucesso!"
                    },
                    "data": {
                      "$ref": "#/components/schemas/BetQuestion"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Dados da requisição inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor ao criar no banco",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/bets/place": {
      "post": {
        "tags": ["Bolão"],
        "summary": "Registra o palpite (aposta) de um convidado",
        "description": "Registra a aposta de um convidado em uma determinada pergunta do bolão. Valida se o convidado confirmou presença, se a pergunta existe, se o formato da resposta está adequado e se o convidado já realizou um palpite para a pergunta específica.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceBetInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Aposta registrada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "example": "Palpite registrado com sucesso!"
                    },
                    "data": {
                      "$ref": "#/components/schemas/GuestBet"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erro de validação ou regra de negócio violada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Erro interno do servidor ao persistir a aposta",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RsvpInput": {
        "type": "object",
        "required": ["name", "email", "phone_number", "will_go"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Nome completo do convidado. Deve conter entre 2 e 100 caracteres.",
            "example": "Maria Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "E-mail único do convidado.",
            "example": "maria.silva@example.com"
          },
          "phone_number": {
            "type": "string",
            "description": "Número de telefone do convidado. Qualquer caractere não numérico será removido. O DDI brasileiro (+55) será injetado automaticamente se estiver ausente.",
            "example": "(11) 99999-9999"
          },
          "will_go": {
            "type": "boolean",
            "description": "Informa se o convidado confirma presença na festa (true) ou rejeita o convite (false).",
            "example": true
          }
        }
      },
      "Rsvp": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Identificador único (UUID) autogerado no banco de dados.",
            "example": "d3b07384-d113-4ec5-a587-c50259b67484"
          },
          "name": {
            "type": "string",
            "description": "Nome completo do convidado.",
            "example": "Maria Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "E-mail do convidado.",
            "example": "maria.silva@example.com"
          },
          "phone_number": {
            "type": "string",
            "description": "Telefone higienizado com DDI +55.",
            "example": "+5511999999999"
          },
          "will_go": {
            "type": "boolean",
            "description": "Resposta de presença na festa.",
            "example": true
          }
        }
      },
      "BetQuestionInput": {
        "type": "object",
        "required": ["title", "type"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 5,
            "description": "Título da pergunta do bolão.",
            "example": "Quem vai comer mais pedaços de pizza?"
          },
          "type": {
            "type": "string",
            "enum": ["TEXT", "NUMBER", "GUEST_SELECT"],
            "description": "Tipo de campo que será renderizado no frontend e sua forma de validação.",
            "example": "GUEST_SELECT"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Lista opcional de strings para múltipla escolha fixa (ex: nomes de países de destino para lua de mel).",
            "example": ["Grécia", "Itália", "Japão"]
          }
        }
      },
      "BetQuestion": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Identificador único (UUID) da pergunta.",
            "example": "b8f07271-e943-4ac5-8123-c50259b67111"
          },
          "title": {
            "type": "string",
            "description": "Título da pergunta.",
            "example": "Quem vai comer mais pedaços de pizza?"
          },
          "type": {
            "type": "string",
            "description": "Tipo de renderização/validação.",
            "example": "GUEST_SELECT"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Opções fixas de resposta cadastrada.",
            "example": []
          }
        }
      },
      "PlaceBetInput": {
        "type": "object",
        "required": ["rsvpId", "questionId", "value"],
        "properties": {
          "rsvpId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID do convidado que está realizando a aposta.",
            "example": "d3b07384-d113-4ec5-a587-c50259b67484"
          },
          "questionId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID da pergunta em que o convidado está apostando.",
            "example": "b8f07271-e943-4ac5-8123-c50259b67111"
          },
          "value": {
            "type": "string",
            "description": "Palpite da aposta. Se a pergunta for GUEST_SELECT, deve ser o UUID de um convidado confirmado. Se for NUMBER, deve ser numérico.",
            "example": "a1b2c3d4-e5f6-7a8b-9c0d-e1f2a3b4c5d6"
          }
        }
      },
      "GuestBet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "UUID da aposta.",
            "example": "ffb07384-c113-4ec5-b587-c50259b67444"
          },
          "rsvpId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID do convidado que apostou.",
            "example": "d3b07384-d113-4ec5-a587-c50259b67484"
          },
          "questionId": {
            "type": "string",
            "format": "uuid",
            "description": "UUID da pergunta correspondente.",
            "example": "b8f07271-e943-4ac5-8123-c50259b67111"
          },
          "value": {
            "type": "string",
            "description": "A resposta salva.",
            "example": "a1b2c3d4-e5f6-7a8b-9c0d-e1f2a3b4c5d6"
          }
        }
      },
      "QuestionWithOdds": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "UUID da pergunta.",
            "example": "b8f07271-e943-4ac5-8123-c50259b67111"
          },
          "title": {
            "type": "string",
            "description": "Título da pergunta.",
            "example": "Quem vai comer mais pedaços de pizza?"
          },
          "type": {
            "type": "string",
            "description": "Tipo de pergunta.",
            "example": "GUEST_SELECT"
          },
          "totalVotes": {
            "type": "integer",
            "description": "Quantidade total de convidados que responderam à pergunta.",
            "example": 100
          },
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OptionWithOdd"
            },
            "description": "Lista de opções da pergunta acompanhadas de seus votos e odds calculadas em tempo real."
          }
        }
      },
      "OptionWithOdd": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "description": "ID/valor correspondente à opção (ex: UUID do candidato ou texto).",
            "example": "a1b2c3d4-e5f6-7a8b-9c0d-e1f2a3b4c5d6"
          },
          "label": {
            "type": "string",
            "description": "Rótulo legível para visualização no front-end (ex: Nome do candidato ou o próprio texto).",
            "example": "Thiago"
          },
          "votes": {
            "type": "integer",
            "description": "Quantidade de convidados que escolheram esta opção.",
            "example": 50
          },
          "odd": {
            "type": "number",
            "format": "float",
            "description": "Multiplicador dinâmico calculado com base no totalizador de apostas.",
            "example": 2.0
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "error"
          },
          "message": {
            "type": "string",
            "example": "Falha de validação nos dados enviados."
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Lista de mensagens detalhadas de validação (retornado com código HTTP 400).",
            "example": [
              "O campo 'title' é obrigatório.",
              "Apenas convidados que confirmaram presença podem participar do bolão."
            ]
          },
          "error": {
            "type": "string",
            "description": "Descrição do erro interno técnico gerado pelo banco de dados ou runtime (retornado com código HTTP 500).",
            "example": "Connection timed out..."
          }
        }
      }
    }
  }
}
