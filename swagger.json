{
  "openapi": "3.0.0",
  "info": {
    "title": "Engagement Invite API",
    "version": "1.0.0",
    "description": "API em Express com TypeScript configurada para rodar no Vercel"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    },
    {
      "url": "https://{vercelUrl}",
      "description": "Servidor de Produção (Vercel)",
      "variables": {
        "vercelUrl": {
          "default": "engagement-invite-api.vercel.app"
        }
      }
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Rota de boas-vindas da API",
        "responses": {
          "200": {
            "description": "API online",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "status": { "type": "string" },
                    "version": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api": {
      "get": {
        "summary": "Status do roteador da API",
        "responses": {
          "200": {
            "description": "Resposta do roteador principal",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "summary": "Health check do servidor",
        "responses": {
          "200": {
            "description": "API saudável",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" },
                    "uptime": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/db-test": {
      "get": {
        "summary": "Testa a conexão com o banco de dados Postgres via Neon",
        "responses": {
          "200": {
            "description": "Conectado ao banco de dados com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "result": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "db_time": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro de conexão com o banco",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
