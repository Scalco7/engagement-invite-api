// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Rsvp {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  phone_number String     @unique
  will_go      Boolean
  bets         GuestBet[]
}

model BetQuestion {
  id      String     @id @default(uuid())
  title   String
  type    String     // "TEXT", "NUMBER", or "GUEST_SELECT"
  options String[]   // Opcional: para múltipla escolha fixa
  bets    GuestBet[]
}

model GuestBet {
  id         String      @id @default(uuid())
  rsvpId     String
  rsvp       Rsvp        @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  questionId String
  question   BetQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value      String      // Armazena a resposta (ID do convidado, número ou texto)

  @@unique([rsvpId, questionId])
}
