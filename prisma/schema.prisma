// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Rsvp {
  id           String  @id @default(uuid())
  name         String
  phone_number String
  will_go      Boolean
}
